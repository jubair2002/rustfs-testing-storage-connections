# Optional: set to "false" to see AWS SDK Node version notices (SDK will require Node 22 after Jan 2027)
# AWS_SDK_JS_NODE_VERSION_SUPPORT_WARNING_DISABLED=true

# Server
PORT=3000
SESSION_SECRET=your-session-secret-long-and-random
DATABASE_PATH=./data/app.db

# RustFS (S3-compatible). Point at your local RustFS gateway.
S3_ENDPOINT=http://127.0.0.1:9000   # change this to your RustFS gateway endpoint
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key-id   # change this to your RustFS gateway access key id
S3_SECRET_ACCESS_KEY=your-secret-access-key   # change this to your RustFS gateway secret access key
S3_BUCKET=your-bucket-name   # change this to your RustFS gateway bucket name
# Required for most self-hosted S3 APIs (MinIO-style path addressing)
S3_FORCE_PATH_STYLE=true   # change this to your RustFS gateway force path style
